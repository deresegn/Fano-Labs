import express from 'express';
import cors from 'cors';

const PORT = Number(process.env.PORT) || 3001;
const OLLAMA_URL = process.env.OLLAMA_URL || 'http://127.0.0.1:11434';

const app = express();

// CORS for Tauri + local dev
app.use(cors({
  origin: ['tauri://localhost', 'http://localhost:5173', 'http://127.0.0.1:3001', 'http://localhost:3001', '*'],
  methods: ['GET','POST','PUT','DELETE','OPTIONS'],
  allowedHeaders: ['Content-Type','Authorization'],
}));
app.options('*', cors());

app.use(express.json());
app.use(express.urlencoded({ extended: true }));

// Simple request logger
app.use((req, _res, next) => {
  console.log(new Date().toISOString(), req.method, req.url);
  next();
});

// Health endpoints
app.get(['/health', '/api/health', '/v1/health'], (_req, res) => {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.json({ ok: true, status: 'ok', timestamp: new Date().toISOString() });
});

// List available Ollama models
app.get('/models', async (_req, res) => {
  try {
    const r = await fetch(`${OLLAMA_URL}/api/tags`);
    if (!r.ok) throw new Error(`Ollama /api/tags ${r.status}`);
    const data = await r.json(); // { models: [ { name, ...}, ... ] }
    const models: string[] = Array.isArray(data?.models)
      ? data.models.map((m: any) => m.name).filter(Boolean)
      : [];
    res.json({ models });
  } catch (err: any) {
    console.error('GET /models error:', err?.message || err);
    // fall back to a safe default
    res.json({ models: ['codellama:7b-code'] });
  }
});

// Generate code via Ollama
app.post('/generate', async (req, res) => {
  const { prompt, model = 'codellama:7b-code', language } = req.body || {};
  if (!prompt || typeof prompt !== 'string') {
    return res.status(400).json({ error: 'Missing "prompt" (string)' });
  }
  try {
    const fullPrompt =
      language && typeof language === 'string'
        ? `Write ${language} code.\n${prompt}`
        : prompt;

    const r = await fetch(`${OLLAMA_URL}/api/generate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model,
        prompt: fullPrompt,
        stream: false
      }),
    });

    if (!r.ok) {
      const txt = await r.text().catch(() => '');
      throw new Error(`Ollama /api/generate ${r.status} ${txt}`);
    }

    const data = await r.json(); // { response: string, ... }
    const text: string = (data && data.response) || '';
    res.json({ text, model });
  } catch (err: any) {
    console.error('POST /generate error:', err?.message || err);
    res.status(500).json({ error: 'Generation failed' });
  }
});

app.listen(PORT, () => {
  console.log(`🚀 FANO-LABS backend server running on http://127.0.0.1:${PORT}`);
  console.log(`📊 Health check: http://127.0.0.1:${PORT}/health`);
});
