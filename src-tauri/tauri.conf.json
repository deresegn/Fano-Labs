{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FANO-LABS",
  "version": "1.0.0",
  "identifier": "com.fano.labs",
  "build": {
    "beforeBuildCommand": "npm run build && npm run build:backend",
    "beforeDevCommand": "npm run dev:frontend",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "FANO-LABS",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": [
      "../backend/dist",
      "../backend/node_modules",
      "../backend/package.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {}
  }
}
