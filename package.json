{
  "name": "fano-labs",
  "version": "1.0.0",
  "description": "Local AI-powered code editor",
  "main": "backend/server.ts",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "tsx watch backend/server.ts",
    "dev:frontend": "cd frontend && vite",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && vite build",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "tauri": "tauri",
    "tauri:dev": "concurrently \"npm run dev:backend\" \"tauri dev\"",
    "tauri:build": "npm run build && tauri build",
    "tauri:preview": "tauri dev --no-backend",
    "generate-icon": "node scripts/download-png-icon.js",
    "start-app": "./scripts/start-app.sh",
    "start-fanolabs": "./scripts/start-fanolabs.sh"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "monaco-editor": "^0.52.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "keywords": [
    "ai",
    "code-editor",
    "local",
    "ollama",
    "tauri",
    "desktop"
  ],
  "author": "Dawit",
  "license": "MIT"
}